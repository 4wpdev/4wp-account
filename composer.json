{
	"name": "4wp-dev/4wp-account",
	"description": "4WP Account — social OAuth login for WordPress.",
	"type": "wordpress-plugin",
	"version": "1.0.2",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"4wpdev/4wp-dev-toolkit": "@dev"
	},
	"repositories": [
		{
			"type": "path",
			"url": "../4wp-dev-toolkit",
			"options": {
				"symlink": true
			}
		}
	],
	"autoload": {
		"psr-4": {
			"ForWP\\Auth\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"ForWP\\Auth\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"test": "phpunit"
	}
}
