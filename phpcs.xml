<?xml version="1.0"?>
<ruleset name="4WP Account">
	<description>PHPCS for 4wp-account (extends 4wp-dev-toolkit).</description>

	<rule ref="../4wp-dev-toolkit/phpcs.xml.dist"/>

	<file>4wp-account.php</file>
	<file>includes</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>

	<config name="text_domain" value="4wp-account"/>
</ruleset>
